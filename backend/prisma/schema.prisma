datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  role     Role   @default(CUSTOMER)

  // V2 Trust & Analytics
  isVerified Boolean @default(false)
  rating     Float   @default(5.0)
  totalSales Int     @default(0)

  // V3 Farmer Profile Extension
  farmName        String?
  farmSize        Float? // In acres or hectares
  experienceYears Int?
  certifications  Json? // Array of certification strings/objects
  district        String?

  // V4 Buyer Profile Extension
  businessName      String?
  industryType      String? // Retailer, Exporter, Processor, Restaurant
  businessLicense   String? // URL to uploaded document
  onTimePaymentRate Float   @default(100.0)
  farmerRating      Float   @default(5.0)

  // V5 Logistics Provider Extension
  fleetSize           Int     @default(1)
  vehicleTypes        Json? // e.g. ["Cold Truck", "Pickup"]
  serviceRegions      Json? // e.g. ["Greater Accra", "Ashanti"]
  deliverySuccessRate Float   @default(100.0)
  insuranceVerified   Boolean @default(false)

  products       Product[]
  orders         Order[]
  chats          Chat[]
  messages       Message[]
  notifications  Notification[]
  wallet         Wallet?
  raisedDisputes Dispute[]      @relation("DisputeRaisedBy")

  // V5 Logistics Relations
  vehicles          Vehicle[]
  drivingRoutes     DeliveryRoute[]      @relation("DriverRoutes")
  managedWarehouses Warehouse[]
  storedInventory   WarehouseInventory[]

  createdAt DateTime @default(now())
}

model Product {
  id          String   @id @default(uuid())
  name        String
  price       Float
  imageUrls   String[]
  videoUrl    String?
  description String?
  category    Category @default(OTHER)

  // V2 Advanced Product Data
  region            String   @default("Greater Accra")
  availableQuantity Int      @default(1)
  minOrderQuantity  Int      @default(1)
  harvestDate       DateTime @default(now())
  qualityGrade      String   @default("Standard")
  isOrganic         Boolean  @default(false)
  views             Int      @default(0)
  isSoldOut         Boolean  @default(false)

  farmer    User     @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  farmerId  String
  orders    Order[]
  chats     Chat[]
  createdAt DateTime @default(now())
}

enum Category {
  VEGETABLES
  FRUITS
  DAIRY
  MEAT
  GRAINS
  OTHER
}

model Order {
  id         String  @id @default(uuid())
  customer   User    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  quantity   Int     @default(1)
  totalprice Float

  // V2 Logistics & Payments
  paymentMethod     String  @default("ESCROW") // MoMo, Bank, Escrow
  paymentStatus     String  @default("PENDING") // PENDING, HELD, RELEASED, REFUNDED
  logisticsPartner  String?
  deliveryCost      Float   @default(0)
  deliveryRegion    String  @default("Standard Delivery")
  isRecurring       Boolean @default(false)
  recurringInterval String? // WEEKLY, MONTHLY

  updatedAt DateTime       @updatedAt
  status    OrderStatus    @default(pending)
  dispute   Dispute?
  delivery  DeliveryRoute?
  createdAt DateTime       @default(now())
}

model Chat {
  id         String    @id @default(uuid())
  customer   User      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  messages   Message[]
  createdAt  DateTime  @default(now())
}

model Message {
  id       String      @id @default(uuid())
  chat     Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId   String
  sender   User        @relation(fields: [senderId], references: [id], onDelete: Cascade)
  senderId String
  content  String
  type     MessageType @default(TEXT)

  // Negotiation Fields
  offerPrice    Float?
  offerQuantity Int?
  isAccepted    Boolean? // For offers and contracts

  status       MessageStatus       @default(sent)
  readStatus   MessageReadStatus   @default(unread)
  deleteStatus MessageDeleteStatus @default(notDeleted)
  createdAt    DateTime            @default(now())
}

enum MessageType {
  TEXT
  OFFER
  CONTRACT
}

enum MessageStatus {
  sent
  received
}

enum MessageReadStatus {
  read
  unread
}

enum MessageDeleteStatus {
  deleted
  notDeleted
}

model Notification {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum OrderStatus {
  pending
  processing
  packed
  shipped
  delivered
  cancelled
  completed
  disputed
}

enum Role {
  FARMER
  CUSTOMER
  ADMIN
  LOGISTICS
}

model Wallet {
  id            String        @id @default(uuid())
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String        @unique
  balance       Float         @default(0)
  escrowBalance Float         @default(0)
  currency      String        @default("GHS")
  transactions  Transaction[]
  updatedAt     DateTime      @updatedAt
  createdAt     DateTime      @default(now())
}

model Transaction {
  id          String   @id @default(uuid())
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  walletId    String
  amount      Float
  type        String // DEPOSIT, WITHDRAWAL, ESCROW_HOLD, ESCROW_RELEASE
  status      String // PENDING, COMPLETED, FAILED
  reference   String? // e.g. MoMo reference, Order ID
  description String?
  createdAt   DateTime @default(now())
}

model Dispute {
  id          String   @id @default(uuid())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String   @unique
  raisedBy    User     @relation("DisputeRaisedBy", fields: [raisedById], references: [id])
  raisedById  String
  reason      String
  status      String   @default("OPEN") // OPEN, UNDER_REVIEW, RESOLVED_REFUND, RESOLVED_RELEASE
  evidenceUrl String?
  adminNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String // e.g., ORDER_CREATED, PAYMENT_ESCROWED, DISPUTE_RAISED, ADMIN_RESOLUTION
  entityId    String // ID of the related entity (Order, Dispute, Wallet)
  entityType  String // ORDER, DISPUTE, WALLET
  details     Json? // Store before/after states or specific metadata
  performedBy String? // User ID or 'SYSTEM'
  createdAt   DateTime @default(now())
}

// ==========================================
// V5 LOGISTICS & FLEET EXPANSION MODELS
// ==========================================

model Vehicle {
  id              String    @id @default(uuid())
  owner           User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId         String
  licensePlate    String    @unique
  vehicleType     String // Pickup, 10-Ton Truck, Cold Storage
  capacityMT      Float // Metric tons
  isColdStorage   Boolean   @default(false)
  insuranceExpiry DateTime?
  status          String    @default("AVAILABLE") // AVAILABLE, IN_TRANSIT, MAINTENANCE

  deliveryRoutes DeliveryRoute[]

  createdAt DateTime @default(now())
}

model DeliveryRoute {
  id        String   @id @default(uuid())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String   @unique
  driver    User?    @relation("DriverRoutes", fields: [driverId], references: [id])
  driverId  String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])
  vehicleId String?

  pickupLocation  String
  pickupLat       Float?
  pickupLng       Float?
  dropoffLocation String
  dropoffLat      Float?
  dropoffLng      Float?
  estimatedETA    DateTime?
  actualDelivery  DateTime?
  currentLat      Float?
  currentLng      Float?

  routeStatus        String   @default("PENDING") // PENDING, ACCEPTED, AT_PICKUP, IN_TRANSIT, DELIVERED
  driverNotes        String?
  proofOfDeliveryUrl String? // Photo or signature
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Warehouse {
  id              String               @id @default(uuid())
  manager         User                 @relation(fields: [managerId], references: [id])
  managerId       String
  name            String
  location        String
  totalCapacityMT Float
  usedCapacityMT  Float                @default(0)
  hasColdStorage  Boolean              @default(false)
  operatingHours  String?
  pricingPerMT    Float                @default(0) // Cost per MT per day
  inventories     WarehouseInventory[]
  createdAt       DateTime             @default(now())
}

model WarehouseInventory {
  id          String    @id @default(uuid())
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  warehouseId String
  owner       User      @relation(fields: [ownerId], references: [id])
  ownerId     String // Usually a BUYER storing bulk purchases
  productName String
  quantityMT  Float
  storedAt    DateTime  @default(now())
  expiryDate  DateTime?
  status      String    @default("STORED") // STORED, DISPATCHED
}

// ==========================================
// AGRIC-NEWS MODULE
// ==========================================

model AgricNews {
  id           String   @id @default(uuid())
  title        String
  summary      String
  content      String?  @db.Text
  source       String
  image        String?
  url          String   @unique
  category     String
  region       String?
  published_at DateTime
  created_at   DateTime @default(now())
}
